{
  "expo": {
    "name": "ArrowVerse-Multiplayer",
    "slug": "arrow-escape",
    "version": "0.3.2",
    "orientation": "portrait",
    "scheme": "arrowversemultiplayer",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F1E8",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1466180289159501~2686527604",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "android": {
      "package": "com.app.arrow_verse",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F6F1E8"
      }
    },
    "ios": {
      "bundleIdentifier": "com.app.arrowverse",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "7b5fe8bb-09c9-4011-9587-a35a9f544234"
      }
    },
    "owner": "kazal-tech"
  }
}
