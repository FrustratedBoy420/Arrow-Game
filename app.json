{
  "expo": {
    "name": "Arrow Escape",
    "slug": "arrow-escape",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "arrowescape",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F1E8",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "android": {
      "package": "com.arrowescape.mvp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F6F1E8"
      }
    },
    "ios": {
      "bundleIdentifier": "com.arrowescape.mvp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "0c562cb9-3a12-4ac0-b75f-f385d23a5255"
      }
    },
    "owner": "mridul_jaiswal_420"
  }
}
